# =============================================================================
# .bashrc additions for Claude Code (WSL / Linux)
# =============================================================================
# PURPOSE:  Add these lines to your ~/.bashrc to configure your shell for
#           Claude Code development. Copy the lines you need, or source
#           this file from your .bashrc.
#
# HOW TO USE:
#   Option A: Copy individual lines into your ~/.bashrc
#   Option B: Add this line to your ~/.bashrc:
#             source ~/path/to/.bashrc-additions.example
# =============================================================================

# --- Claude Code model selection ---
# Tells Claude Code which AI model to use. claude-opus-4-6 is the most capable.
export ANTHROPIC_MODEL=claude-opus-4-6

# --- Local binaries ---
# Adds ~/bin to your PATH so you can run tools installed there
# (like wsl-notify-send.exe) without typing the full path.
export PATH="$HOME/bin:$PATH"

# --- clone() convenience function (WSL only) ---
# Quick function to clone a GitHub repo into ~/projects/ and cd into it.
# Usage: clone owner/repo
#        clone https://github.com/owner/repo.git
#
# Example: clone anthropics/claude-code
#          -> clones into ~/projects/claude-code and cd's there
clone() {
    local repo="$1"
    local dir

    # If the argument looks like a full URL, extract the repo name
    if [[ "$repo" == http* ]]; then
        dir=$(basename "$repo" .git)
    else
        # Handle "owner/repo" format
        dir=$(basename "$repo")
        repo="https://github.com/$repo.git"
    fi

    # Clone into ~/projects/ and cd into the new directory
    git clone "$repo" "$HOME/projects/$dir" && cd "$HOME/projects/$dir"
}

# --- Node.js version manager (optional) ---
# If you use nvm to manage Node versions, uncomment these lines:
# export NVM_DIR="$HOME/.nvm"
# [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
# [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
