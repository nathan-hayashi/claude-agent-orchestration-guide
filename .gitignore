# ============================================
# .gitignore for Claude Code Orchestration Guide
# Prevents secrets and sensitive data from being committed
# ============================================

# --- Secrets and API Keys ---
# NEVER commit these files. They contain sensitive credentials.
.env
.env.*
.env.local
.env.production
*.key
*.pem
*.p12
*.pfx
credentials*
**/secrets/**
**/*secret*
**/*credential*
.dev.vars
.dev.vars.*

# --- Claude Code Local Settings ---
# Personal preferences that should not be shared
.claude/settings.local.json

# --- OS Artifacts ---
# Generated by operating systems, not part of the project
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor/IDE Settings ---
# Personal editor configuration
.idea/
.vscode/
*.swp
*.swo
*~

# --- Node.js ---
# Dependencies and build artifacts (if tutorial exercises create these)
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Python ---
# Build artifacts from any Python scripts
__pycache__/
*.pyc
*.pyo
*.egg-info/

# --- Temporary Files ---
# Validation and testing artifacts
/tmp-validate-*/
*.tmp
*.bak
